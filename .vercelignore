# Vercel ignore file - Force fresh builds on every deploy
# This clears all cached builds and forces Vercel to rebuild from scratch

# Vercel cache directories - MUST be ignored to prevent stale builds
.cache/
.vercel/cache/
.vercel/output/

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment files (never deploy these)
.env
.env.local
.env.*.local
.env.production
.env.development

# Git
.git/
.gitignore

# Node modules (if any)
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip-delete-this-directory.txt

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# OS files
Thumbs.db
.DS_Store

# Local scripts
deploy.bat
run.bat
setup.bat
setup-git.bat

# Documentation (optional - reduce build size)
# README.md
# DEPLOYMENT.md
# QUICKSTART.md

# Database files
*.db
*.sqlite
*.sqlite3

# Supabase local development
.temp/
