# Vercel ignore file
# Files to ignore during Vercel deployment

# Development files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Node modules (if any)
node_modules/

# Build artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Local scripts
deploy.bat
run.bat

# Documentation (optional - include if you want README served)
# README.md
