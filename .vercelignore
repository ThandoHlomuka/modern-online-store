# Vercel ignore file - clear cache on every deploy
# This forces Vercel to rebuild from scratch

# Force cache clear
.cache/
.vercel/cache/

# Development files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Node modules
node_modules/

# Build artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Local scripts
deploy.bat
run.bat

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.eggs/
*.egg-info/
