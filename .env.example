# Modern Online Store - Environment Variables
# Copy this file to .env and fill in your values

# ==================== Application ====================
# Flask secret key (generate a random string for production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==================== Supabase Configuration ====================
# Get these from your Supabase project settings: https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=avatars

# ==================== Database (Alternative) ====================
# If not using Supabase, use a regular PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:port/database

# ==================== Bobgo Shipping API ====================
# Get API key from Bobgo: https://bobgo.co.za
BOBGO_API_URL=https://api.bobgo.co.za/v1
BOBGO_API_KEY=your-bobgo-api-key

# ==================== Currency Exchange API (Optional) ====================
# Get free API key from: https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# ==================== Payment Gateway (Optional) ====================
# Stripe keys for payment processing
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# ==================== Email Configuration (Optional) ====================
# For order confirmations and password reset
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@modernstore.com

# ==================== Flask Environment ====================
FLASK_ENV=development
# Set to 'production' in production
DEBUG=True
