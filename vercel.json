{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "SECRET_KEY": "modern-store-vercel-secret-key-change-in-dashboard-xyz123",
    "SUPABASE_URL": "https://placeholder.supabase.co",
    "SUPABASE_KEY": "placeholder-key-update-in-vercel-dashboard",
    "SUPABASE_DB_URL": "postgresql://placeholder:placeholder@placeholder.supabase.co:5432/postgres",
    "BOBGO_API_KEY": "placeholder-bobgo-key"
  },
  "outputDirectory": "static"
}
