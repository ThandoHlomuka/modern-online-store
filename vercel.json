{
  "version": 2,
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "vercel_app.py"
    }
  ],
  "build": {
    "env": {
      "PIP_NO_CACHE_DIR": "1",
      "PIP_DISABLE_PIP_VERSION_CHECK": "1"
    }
  }
}
